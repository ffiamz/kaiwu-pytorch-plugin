#: ../../source/modules/kaiwu.torch_plugin.md:1
msgid "模块手册"
msgstr "模块手册"

#: ../../source/modules/kaiwu.torch_plugin.md:3
msgid "Module contents"
msgstr "模块内容"

#: kaiwu.torch_plugin:1 of
msgid "Kaiwu-Pytorch-Plugin public API."
msgstr "开物 PyTorch 插件公共 API。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine:1
#: kaiwu.torch_plugin.restricted_boltzmann_machine.RestrictedBoltzmannMachine:1
#: of
msgid "基类：:py:class:`~kaiwu.torch_plugin.abstract_boltzmann_machine.AbstractBoltzmannMachine`"
msgstr "基类：:py:class:`~kaiwu.torch_plugin.abstract_boltzmann_machine.AbstractBoltzmannMachine`"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine:1 of
msgid "Boltzmann Machine."
msgstr "玻尔兹曼机。"

#: ../../source/modules/kaiwu.torch_plugin.md
msgid "参数"
msgstr ""

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine:3 of
msgid "Total number of nodes in the model."
msgstr "模型中的节点总数。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine:5 of
msgid "Quadratic coefficient with shape ``[num_nodes, num_nodes]``."
msgstr "形状为 ``[num_nodes, num_nodes]`` 的二次项系数。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine:8 of
msgid "linear bias, shape is [num_nodes]"
msgstr "线性偏置，形状为 [num_nodes]。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine:10 of
msgid "Device for tensor construction; uses CPU when ``None``."
msgstr "用于构造张量的设备；为 ``None`` 时使用 CPU。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.clip_parameters:1
#: kaiwu.torch_plugin.restricted_boltzmann_machine.RestrictedBoltzmannMachine.clip_parameters:1
#: of
msgid "Clip linear and quadratic bias weights in-place."
msgstr "原地裁剪线性和二次偏置权重。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.clip_parameters:3
#: kaiwu.torch_plugin.restricted_boltzmann_machine.RestrictedBoltzmannMachine.clip_parameters:3
#: of
msgid "Range for quadratic weights. for example, [-1, 1]"
msgstr "二次项权重的范围，例如 [-1, 1]。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.clip_parameters:5
#: kaiwu.torch_plugin.restricted_boltzmann_machine.RestrictedBoltzmannMachine.clip_parameters:5
#: of
msgid "Range for linear weights. for example, [-1, 1]"
msgstr "线性权重的范围，例如 [-1, 1]。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.condition_sample:1
#: of
msgid "Sample from the Boltzmann Machine given some nodes."
msgstr "在给定部分节点的条件下从玻尔兹曼机中采样。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.condition_sample:3
#: of
msgid "Optimizer used for sampling from the model."
msgstr "用于从模型中采样的优化器。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.condition_sample:5
#: of
msgid "State of the visible layer."
msgstr "可见层状态。"

#: ../../source/modules/kaiwu.torch_plugin.md
msgid "返回"
msgstr ""

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.condition_sample:7
#: of
msgid ""
"Spins sampled from the model     (shape determined by ``sampler`` and "
"``sample_params``)."
msgstr "从模型中采样的自旋（形状由 ``sampler`` 和 ``sample_params`` 决定）。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.condition_sample:9
#: of
msgid "Spins sampled from the model"
msgstr "从模型中采样的自旋。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.condition_sample:10
#: of
msgid "(shape determined by ``sampler`` and ``sample_params``)."
msgstr "（形状由 ``sampler`` 和 ``sample_params`` 决定）。"

#: ../../source/modules/kaiwu.torch_plugin.md
msgid "返回类型"
msgstr ""

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.forward:1
#: kaiwu.torch_plugin.restricted_boltzmann_machine.RestrictedBoltzmannMachine.forward:1
#: of
msgid "Compute the Hamiltonian."
msgstr "计算哈密顿量。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.forward:3 of
msgid ""
"Tensor of shape (B, N), where B is batch size, N is the number of "
"variables in the model."
msgstr "形状为 (B, N) 的张量，其中 B 是批次大小，N 是模型中的变量数。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.forward:7
#: kaiwu.torch_plugin.restricted_boltzmann_machine.RestrictedBoltzmannMachine.forward:7
#: of
msgid "Hamiltonian of shape (B,)."
msgstr "形状为 (B,) 的哈密顿量。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.gibbs_sample:1 of
msgid "Sample from the Boltzmann Machine."
msgstr "从玻尔兹曼机中采样。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.gibbs_sample:3 of
msgid "Number of Gibbs sampling steps."
msgstr "吉布斯采样步数。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.gibbs_sample:5 of
msgid ""
"State of the visible layer, shape (B, num_visible). If ``None``, randomly"
" initialize visible layer."
msgstr "可见层状态，形状为 (B, num_visible)。若为 ``None``，则随机初始化可见层。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.gibbs_sample:8 of
msgid "Number of samples. If ``None``, uses batch size of s_visible."
msgstr "样本数量；若为 ``None``，则使用 s_visible 的批次大小。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.hidden_bias:1 of
msgid "Get the hidden bias."
msgstr "获取隐藏层偏置。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.hidden_bias:3 of
msgid "Number of hidden nodes."
msgstr "隐藏节点数。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.symmetrized_quadratic_coef:1
#: of
msgid "Quadratic coefficient"
msgstr "二次项系数"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.visible_bias:1 of
msgid "Get the visible bias."
msgstr "获取可见层偏置。"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.visible_bias:3 of
msgid "Number of visible nodes."
msgstr "可见节点数。"

#: kaiwu.torch_plugin.dbn.UnsupervisedDBN:1
#: kaiwu.torch_plugin.qdiffusion.EnergyModel:1
#: kaiwu.torch_plugin.qdiffusion.QDiffusion:1 of
msgid "基类：:py:class:`~torch.nn.modules.module.Module`"
msgstr "基类：:py:class:`~torch.nn.modules.module.Module`"

#: kaiwu.torch_plugin.qdiffusion.EnergyModel:1 of
msgid "Energy-side model interface used by QDiffusion candidate scoring."
msgstr "用于 QDiffusion 候选项评分的能量侧模型接口。"

#: kaiwu.torch_plugin.qdiffusion.EnergyModel.discretize_visible_state:1 of
msgid "Converts visible logits into normalized BM visible conditions."
msgstr "将可见层 logits 转换为归一化的玻尔兹曼机可见层条件。"

#: kaiwu.torch_plugin.qdiffusion.EnergyModel.forward:1 of
msgid "Runs conditioned energy scoring through the PyTorch module API."
msgstr "通过 PyTorch 模块 API 执行条件能量评分。"

#: kaiwu.torch_plugin.qdiffusion.EnergyModel.get_last_stats:1 of
msgid "Returns lightweight sampler diagnostics from the last score call."
msgstr "返回上一次评分调用的轻量级采样器诊断信息。"

#: kaiwu.torch_plugin.qdiffusion.EnergyModel.sample_hidden_state:1 of
msgid "Samples BM hidden states for each visible assignment."
msgstr "为每个可见层赋值采样玻尔兹曼机隐藏层状态。"

#: kaiwu.torch_plugin.qdiffusion.EnergyModel.score_conditioned:1 of
msgid "Scores candidates conditioned on noisy tokens."
msgstr "对以噪声 token 为条件的候选项进行评分。"

#: kaiwu.torch_plugin.qdiffusion.EnergyModel.score_visible_logits:1 of
msgid "Scores visible logits under the conditioned BM energy model."
msgstr "在条件玻尔兹曼机能量模型下对可见层 logits 进行评分。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:1 of
msgid ""
"Energy-guided discrete diffusion wrapper over generic sequence backbones."
" Initializes a QDiffusion model."
msgstr "基于通用序列骨干网络的能量引导离散扩散封装。初始化 QDiffusion 模型。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:4 of
msgid "The class combines two backbone roles:"
msgstr "该类组合了两种骨干网络角色："

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:6 of
msgid "a proposal model that predicts token logits for the current noisy state"
msgstr "预测当前噪声状态 token logits 的提议模型"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:7 of
msgid "an energy model that reranks candidate reconstructions"
msgstr "对候选重建结果重新排序的能量模型"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:9 of
msgid ""
"It exposes both training-oriented APIs such as ``objective`` and "
"decoding-oriented APIs such as ``initialize_state``, ``step``, and "
"``generate``."
msgstr ""
"该类同时提供面向训练的 API，例如 ``objective``；也提供面向解码的 API，例如 "
"``initialize_state``、``step`` 和 ``generate``。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:13 of
msgid "Backbone used to predict proposal logits."
msgstr "用于预测提议 logits 的骨干网络。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:14 of
msgid "Energy-side model used to encode and score candidates."
msgstr "用于编码和评估候选项的能量侧模型。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:15 of
msgid "Special-token metadata required by the generator."
msgstr "生成器所需的特殊 token 元数据。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:16 of
msgid "Optional generation/training configuration."
msgstr "可选的生成/训练配置。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:17 of
msgid "Floating point dtype tracked by the wrapper."
msgstr "封装器跟踪的浮点数据类型。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:18 of
msgid "Optional target device. When omitted, infer from parameters."
msgstr "可选的目标设备；省略时从参数中推断。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion:19 of
msgid "Whether to freeze proposal model parameters."
msgstr "是否冻结提议模型参数。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.energy:1 of
msgid "Scores candidate reconstructions conditioned on the noisy state."
msgstr "对以噪声状态为条件的候选重建结果进行评分。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.energy:3 of
msgid "Noisy token tensor used as conditioning input."
msgstr "用作条件输入的噪声 token 张量。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.energy:4 of
msgid "Candidate clean token tensor to score."
msgstr "待评估的候选干净 token 张量。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.energy:5 of
msgid "Optional attention mask for the energy model."
msgstr "能量模型的可选注意力掩码。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.energy:7 of
msgid "A tensor of scalar energies with shape ``[batch, 1]``."
msgstr "形状为 ``[batch, 1]`` 的标量能量张量。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.forward:1 of
msgid "Runs the proposal model on the current noisy state."
msgstr "在当前噪声状态上运行提议模型。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.forward:3
#: kaiwu.torch_plugin.qdiffusion.QDiffusion.proposal:3 of
msgid "Current noisy token tensor."
msgstr "当前的噪声 token 张量。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.forward:4
#: kaiwu.torch_plugin.qdiffusion.QDiffusion.proposal:4 of
msgid "Additional keyword arguments forwarded to the proposal model."
msgstr "转发给提议模型的附加关键字参数。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.forward:6
#: kaiwu.torch_plugin.qdiffusion.QDiffusion.proposal:6 of
msgid "Proposal logits over the token vocabulary."
msgstr "token 词表上的提议 logits。"

#: ../../source/modules/kaiwu.torch_plugin.md
msgid "抛出"
msgstr ""

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.forward:9 of
msgid "If the proposal model does not implement ``forward``."
msgstr "当提议模型未实现 ``forward`` 时。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.generate:1 of
msgid "Runs a complete iterative decoding loop inside the core class."
msgstr "在核心类中运行完整的迭代解码循环。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.generate:3
#: kaiwu.torch_plugin.qdiffusion.QDiffusion.initialize_state:3 of
msgid "Initial token tensor."
msgstr "初始 token 张量。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.generate:4 of
msgid "Number of decode iterations to run."
msgstr "要执行的解码迭代次数。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.generate:5
#: kaiwu.torch_plugin.qdiffusion.QDiffusion.initialize_state:4
#: kaiwu.torch_plugin.qdiffusion.QDiffusion.step:4 of
msgid "Optional boolean mask of fixed positions."
msgstr "固定位置的可选布尔掩码。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.generate:6 of
msgid "Sampling temperature stored in the decode state."
msgstr "存储在解码状态中的采样温度。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.generate:7 of
msgid "Whether to return the full final state dictionary."
msgstr "是否返回完整的最终状态字典。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.generate:9 of
msgid "Either the final token tensor or the full decode state."
msgstr "最终 token 张量或完整解码状态。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.get_non_special_symbol_mask:1 of
msgid "Returns a boolean mask of editable non-special-token positions."
msgstr "返回可编辑非特殊 token 位置的布尔掩码。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.get_non_special_symbol_mask:3 of
msgid "Token tensor to inspect."
msgstr "待检查的 token 张量。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.get_non_special_symbol_mask:4 of
msgid "Optional boolean mask of positions that should remain fixed."
msgstr "应保持固定位置的可选布尔掩码。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.get_non_special_symbol_mask:6 of
msgid "A boolean mask where ``True`` marks editable non-special positions."
msgstr "布尔掩码，其中 ``True`` 表示可编辑的非特殊位置。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.initialize_state:1 of
msgid "Creates the initial decoding state for an external generation loop."
msgstr "为外部生成循环创建初始解码状态。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.initialize_state:5 of
msgid "Planned number of decode iterations."
msgstr "计划执行的解码迭代次数。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.initialize_state:6 of
msgid "Sampling temperature stored in the state payload."
msgstr "存储在状态载荷中的采样温度。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.initialize_state:8 of
msgid "A mutable state dictionary suitable for repeated ``step`` calls."
msgstr "适用于重复调用 ``step`` 的可变状态字典。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.objective:1 of
msgid "Builds the one-step training objective used by an external loop."
msgstr "构建外部循环使用的单步训练目标。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.objective:3 of
msgid "Batch dictionary containing at least ``batch[\"targets\"]``."
msgstr "至少包含 ``batch[\"targets\"]`` 的批次字典。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.objective:4 of
msgid "Per-sample timestep weighting mode."
msgstr "逐样本时间步加权模式。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.objective:6 of
msgid ""
"A dictionary containing proposal logits, supervision masks, loss weights,"
" and the EBM objective term."
msgstr "包含提议 logits、监督掩码、损失权重和 EBM 目标项的字典。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.proposal:1 of
msgid "Semantic alias around ``forward`` for proposal-side calls."
msgstr "``forward`` 的语义别名，用于提议侧调用。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.step:1 of
msgid "Runs one denoising/reranking step and returns updated state."
msgstr "执行一步去噪/重排序并返回更新后的状态。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.step:3 of
msgid "Current decode state created by ``initialize_state``."
msgstr "由 ``initialize_state`` 创建的当前解码状态。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.step:6 of
msgid "The updated decode state after one iteration."
msgstr "一次迭代后更新的解码状态。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.to:1 of
msgid "Moves the module and refreshes cached device/dtype metadata."
msgstr "移动模块并刷新缓存的设备和 dtype 元数据。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.to:3 of
msgid "Positional arguments forwarded to ``nn.Module.to``."
msgstr "转发给 ``nn.Module.to`` 的位置参数。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.to:4 of
msgid "Keyword arguments forwarded to ``nn.Module.to``."
msgstr "转发给 ``nn.Module.to`` 的关键字参数。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusion.to:6 of
msgid "The moved module instance."
msgstr "移动后的模块实例。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:1 of
msgid "基类：:py:class:`object`"
msgstr "基类：:py:class:`object`"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:1 of
msgid "Configuration for energy-guided discrete generation."
msgstr "能量引导离散生成的配置。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:5 of
msgid "Number of discrete noising steps used by the training objective."
msgstr "训练目标使用的离散加噪步数。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig of
msgid "type"
msgstr "类型"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:8
#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:20 of
msgid "int"
msgstr ""

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:12 of
msgid "Whether to use the coupled corruption variant."
msgstr "是否使用耦合的加噪变体。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:14
#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:45 of
msgid "bool"
msgstr ""

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:18 of
msgid "Number of proposal candidates sampled at each decode step."
msgstr "每个解码步骤采样的提议候选项数量。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:24 of
msgid "Temperature used for proposal-side sampling."
msgstr "提议侧采样使用的温度。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:26
#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:32
#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:39
#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:51
#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:57 of
msgid "float"
msgstr ""

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:30 of
msgid "Gumbel noise scale used during proposal sampling."
msgstr "提议采样期间使用的 Gumbel 噪声尺度。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:36 of
msgid "Temperature used when converting energies into reranking weights."
msgstr "将能量转换为重排序权重时使用的温度。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:43 of
msgid "Whether to disable repetition-collapse resampling."
msgstr "是否禁用重复坍缩重采样。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:49 of
msgid "Frequency threshold that triggers resampling."
msgstr "触发重采样的频率阈值。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:55 of
msgid "Top-p cutoff used during resampling."
msgstr "重采样期间使用的 Top-p 截止值。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:61 of
msgid "Skeptical-remasking strategy string."
msgstr "怀疑式重新掩码策略字符串。"

#: kaiwu.torch_plugin.qdiffusion.QDiffusionConfig:63 of
msgid "str"
msgstr ""

#: kaiwu.torch_plugin.qvae.QVAE:1 of
msgid "基类：:py:class:`~kaiwu.torch_plugin.qvae.AutoEncoderBase`"
msgstr "基类：:py:class:`~kaiwu.torch_plugin.qvae.AutoEncoderBase`"

#: kaiwu.torch_plugin.qvae.QVAE:1 of
msgid "Quantum Variational Autoencoder integrated into AutoEncoderBase framework."
msgstr "集成到 AutoEncoderBase 框架中的量子变分自编码器。"

#: kaiwu.torch_plugin.qvae.QVAE:3 of
msgid "Dimensionality of input features."
msgstr "输入特征的维度。"

#: kaiwu.torch_plugin.qvae.QVAE:5 of
msgid "Activation function for hidden layers."
msgstr "隐藏层的激活函数。"

#: kaiwu.torch_plugin.qvae.QVAE:7 of
msgid ""
"Configuration object containing ``num_latent_units``, ``loss_type``, "
"``dist_beta``, ``kl_beta``, and ``weight_decay``."
msgstr "包含 ``num_latent_units``、``loss_type``、``dist_beta``、``kl_beta`` 和 ``weight_decay`` 的配置对象。"

#: kaiwu.torch_plugin.qvae.QVAE:9 of
msgid "Type of sampler for BM ('sa' or 'cim')."
msgstr "BM 的采样器类型（``sa`` 或 ``cim``）。"

#: kaiwu.torch_plugin.qvae.QVAE:11 of
msgid "Number of batches for conditional decoding (0 = no conditioning)."
msgstr "条件解码的批次数（0 表示不使用条件）。"

#: kaiwu.torch_plugin.qvae.QVAE:13 of
msgid "Pre-created Boltzmann Machine."
msgstr "预先创建的玻尔兹曼机。"

#: kaiwu.torch_plugin.qvae.QVAE:15 of
msgid "Pre-created encoder."
msgstr "预先创建的编码器。"

#: kaiwu.torch_plugin.qvae.QVAE:17 of
